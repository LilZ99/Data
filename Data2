-- MODULE 2: SAFE EVENT MANAGER
-- ════════════════════════════════════════════════════════════
local EventManager = {}
EventManager.__index = EventManager

function EventManager.new(logBuffer)
    return setmetatable({
        _conns  = {},
        _log    = logBuffer,
    }, EventManager)
end

function EventManager:connect(signal, category, handler)
    local conn = signal:Connect(function(...)
        local args = {...}
        local ok, err = pcall(function()
            handler(table.unpack(args))
        end)
        if not ok then
            self._log:write("ERROR", category,
                "Handler exception: " .. tostring(err))
        end
    end)
    self._conns[#self._conns+1] = conn
    return conn
end

function EventManager:disconnectAll()
    for _, c in self._conns do
        if typeof(c) == "RBXScriptConnection" and c.Connected then
            c:Disconnect()
        end
    end
    table.clear(self._conns)
    self._log:write("DEBUG", "SYS", "All connections disconnected.")
end

