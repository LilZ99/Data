-- MODULE 1: CIRCULAR LOG BUFFER
-- ════════════════════════════════════════════════════════════
local LogBuffer = {}
LogBuffer.__index = LogBuffer

function LogBuffer.new(maxSize)
    return setmetatable({
        _buf    = table.create(maxSize),  -- Pre-allocate, tránh resize
        _head   = 1,
        _count  = 0,
        _max    = maxSize,
        _filter = "ALL",  -- Lọc theo level: "ALL" hoặc tên level cụ thể
        _catFilter = "ALL",
        _onWrite = nil,   -- Callback mỗi khi có entry mới → cập nhật UI
    }, LogBuffer)
end

-- Ghi log — O(1) không allocate thêm RAM
function LogBuffer:write(level, category, message, data)
    local entry = {
        t  = os.clock(),
        lv = level or "INFO",
        ct = category or "SYS",
        ms = message or "",
        dt = data,
        id = self._head,  -- ID duy nhất để track
    }
    self._buf[self._head] = entry
    self._head  = (self._head % self._max) + 1
    self._count = math.min(self._count + 1, self._max)

    -- Trigger UI callback bất đồng bộ để không block caller
    if self._onWrite then
        task.defer(self._onWrite, entry)
    end
end

-- Lấy entries theo thứ tự thời gian, áp filter
function LogBuffer:getFiltered(levelFilter, catFilter)
    local all = self:_getAllOrdered()
    if (levelFilter == "ALL" or not levelFilter)
    and (catFilter  == "ALL" or not catFilter) then
        return all
    end
    local result = {}
    for _, e in all do
        local lvOk  = (levelFilter == "ALL") or (e.lv == levelFilter)
        local catOk = (catFilter   == "ALL") or (e.ct == catFilter)
        if lvOk and catOk then
            result[#result+1] = e
        end
    end
    return result
end

function LogBuffer:_getAllOrdered()
    local result = table.create(self._count)
    if self._count == 0 then return result end
    local startIdx = (self._count < self._max)
        and 1
        or self._head  -- Wrap-around
    for i = 1, self._count do
        local idx = ((startIdx + i - 2) % self._max) + 1
        result[i] = self._buf[idx]
    end
    return result
end

function LogBuffer:clear()
    table.clear(self._buf)
    self._head  = 1
    self._count = 0
end

function LogBuffer:getCount() return self._count end

-- Lấy tất cả category hiện có
function LogBuffer:getCategories()
    local seen, cats = {}, {"ALL"}
    for _, e in self:_getAllOrdered() do
        if not seen[e.ct] then
            seen[e.ct] = true
            cats[#cats+1] = e.ct
        end
    end
    return cats
end

