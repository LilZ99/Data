-- ════════════════════════════════════════════════════════════
-- Dùng Object Pool để không tạo/xóa TextLabel liên tục → giảm GC
local RowPool = {}
local ROW_H   = 18

local function getPooledRow()
    if #RowPool > 0 then
        local r = table.remove(RowPool)
        r.Visible = true
        return r
    end
    local f = Instance.new("Frame")
    f.Size              = UDim2.new(1, 0, 0, ROW_H)
    f.BackgroundTransparency = 1
    f.BorderSizePixel   = 0
    f.ZIndex            = 17

    local t = Instance.new("TextLabel", f)
    t.Name              = "Txt"
    t.Size              = UDim2.new(1, -4, 1, 0)
    t.Position          = UDim2.fromOffset(2, 0)
    t.BackgroundTransparency = 1
    t.Font              = Enum.Font.Code
    t.TextSize          = 11
    t.TextXAlignment    = Enum.TextXAlignment.Left
    t.TextYAlignment    = Enum.TextYAlignment.Center
    t.TextTruncate      = Enum.TextTruncate.AtEnd
    t.RichText          = false
    t.ZIndex            = 17
    return f
end

local function recycleRow(row)
    row.Visible = false
    row.Parent  = nil
    RowPool[#RowPool+1] = row
end

