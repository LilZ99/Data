-- MODULE 11: STATS (FPS + RAM)
-- ════════════════════════════════════════════════════════════
do
    local frameCount  = 0
    local lastFPSTime = os.clock()
    local lastStatsUp = 0

    RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
    end)

    RunService.Heartbeat:Connect(function()
        local now = os.clock()
        if now - lastStatsUp < CFG.STATS_UPDATE_HZ then return end
        lastStatsUp = now

        local elapsed = now - lastFPSTime
        local fps     = math.floor(frameCount / elapsed)
        frameCount    = 0
        lastFPSTime   = now

        local mem = math.floor(collectgarbage("count") / 1024 * 10) / 10

        StatsLbl.Text = string.format("FPS:%d | MEM:%.1fMB", fps, mem)

        -- Đổi màu FPS warning
        StatsLbl.TextColor3 = fps < 20 and THEME.DANGER
            or fps < 40 and LEVEL_COLOR.WARN
            or THEME.SUBTEXT
    end)
end

