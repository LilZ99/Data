local function rebuildLogRows()
    -- Recycle rows cũ vào pool
    for _, r in renderedRows do recycleRow(r.frame) end
    table.clear(renderedRows)

    local entries = LOG:getFiltered(
        currentFilter == "ALL" and "ALL" or currentFilter, "ALL"
    )

    -- Giới hạn visible rows để tránh quá nhiều TextLabel
    local startIdx = math.max(1, #entries - CFG.MAX_VISIBLE_ROWS)

    for i = startIdx, #entries do
        local e   = entries[i]
        local row = getPooledRow()
        local col = LEVEL_COLOR[e.lv] or THEME.TEXT

        -- Màu nền xen kẽ nhẹ
        row.BackgroundTransparency = (i % 2 == 0) and 0.97 or 1
        row.BackgroundColor3       = THEME.SURFACE

        local txt = row:FindFirstChild("Txt")
        txt.TextColor3 = col
        txt.Text = string.format("[%.2f] %s | %s | %s",
            e.t, e.lv, e.ct, e.ms)

        row.LayoutOrder = i
        row.Parent      = LogScroll

        renderedRows[#renderedRows+1] = { frame=row, entry=e }
    end

    CountBadge.Text = tostring(LOG:getCount()).." entries"

    -- Auto scroll xuống cuối
    if autoScroll then
        task.defer(function()
            local cs = LogScroll.AbsoluteCanvasSize.Y
            local fs = LogScroll.AbsoluteSize.Y
            if cs > fs then
                LogScroll.CanvasPosition = Vector2.new(0, cs - fs)
            end
        end)
    end

    needsRebuild = false
end

-- Trigger rebuild bất đồng bộ (debounce)
local rebuildPending = false
local function scheduleRebuild()
    if rebuildPending then return end
    rebuildPending = true
    task.defer(function()
        rebuildLogRows()
        rebuildPending = false
    end)
end

LOG._onWrite = function(_)
    scheduleRebuild()
end

