local isOpen = false
local OPEN_SIZE = UDim2.fromOffset(PanelW, PanelH)

local function openPanel()
    isOpen = true
    Panel.Size = UDim2.fromOffset(0, 0)
    Panel.Visible = true
    TweenService:Create(Panel, TW_MED, {Size = OPEN_SIZE}):Play()
    TweenService:Create(Bubble, TW_FAST, {Rotation = 15}):Play()
    scheduleRebuild()
end

local function closePanel()
    isOpen = false
    TweenService:Create(Panel, TW_MED, {Size = UDim2.fromOffset(0,0)}):Play()
    TweenService:Create(Bubble, TW_FAST, {Rotation = 0}):Play()
    task.delay(TW_MED.Time, function()
        if not isOpen then Panel.Visible = false end
    end)
end

Bubble.MouseButton1Click:Connect(function()
    if isOpen then closePanel() else openPanel() end
end)
CloseBtn.MouseButton1Click:Connect(closePanel)

-- Panel drag (kéo qua header)
do
    local drag, ds, pp = false, nil, nil
    Header.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag=true; ds=i.Position; pp=Panel.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not drag then return end
        if i.UserInputType ~= Enum.UserInputType.Touch
        and i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d = i.Position - ds
        Panel.Position = UDim2.new(
            pp.X.Scale, pp.X.Offset + d.X,
            pp.Y.Scale, pp.Y.Offset + d.Y)
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = false
        end
    end)
end

