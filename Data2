local function setFilter(lvl)
    currentFilter = lvl
    for l, b in filterBtns do
        local isActive = (l == lvl)
        local col      = LEVEL_COLOR[l] or THEME.ACCENT
        TweenService:Create(b, TW_FAST, {
            BackgroundColor3 = isActive and (col) or THEME.SURFACE,
            TextColor3       = isActive
                and (l == "ALL" and Color3.new(0,0,0) or Color3.new(1,1,1))
                or col,
        }):Play()
    end
    scheduleRebuild()
end

for lvl, b in filterBtns do
    b.MouseButton1Click:Connect(function() setFilter(lvl) end)
end

