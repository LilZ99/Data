-- Remote log: hook tất cả RemoteEvent trong ReplicatedStorage
local function hookRemotes()
    local RS = game:GetService("ReplicatedStorage")
    local function tryHookRemote(obj)
        if not obj:IsA("RemoteEvent") and not obj:IsA("RemoteFunction") then return end
        local name = obj.Name
        -- Chỉ hook OnClientEvent (phía client)
        if obj:IsA("RemoteEvent") then
            local ok = pcall(function()
                EV_MGR:connect(obj.OnClientEvent, "REMOTE", function(...)
                    local args = {...}
                    local summary = {}
                    for i, v in args do
                        summary[i] = type(v).."("..tostring(v):sub(1,20)..")"
                    end
                    LOG:write("EVENT", "REMOTE",
                        name..": "..table.concat(summary," | "))
                end)
            end)
            if not ok then
                LOG:write("DEBUG","REMOTE","Không hook được: "..name)
            end
        end
    end

    -- Hook toàn bộ existing remotes
    for _, obj in RS:GetDescendants() do
        tryHookRemote(obj)
    end
    -- Hook remotes mới được tạo
    EV_MGR:connect(RS.DescendantAdded, "REMOTE", tryHookRemote)
    LOG:write("INFO", "REMOTE",
        string.format("Đã scan %d RemoteEvents.", #RS:GetDescendants()))
end

-- Gọi hookRemotes trong pcall để không crash nếu quyền bị giới hạn
local ok, err = pcall(hookRemotes)
if not ok then
    LOG:write("WARN", "REMOTE", "hookRemotes thất bại: "..tostring(err))
end

