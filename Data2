local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p; return c
end

local function padding(p, all, lr, tb)
    local pad = Instance.new("UIPadding")
    local a = UDim.new(0, all or 0)
    pad.PaddingTop    = UDim.new(0, tb or all or 0)
    pad.PaddingBottom = UDim.new(0, tb or all or 0)
    pad.PaddingLeft   = UDim.new(0, lr or all or 0)
    pad.PaddingRight  = UDim.new(0, lr or all or 0)
    pad.Parent = p; return pad
end

local function stroke(p, color, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color       = color or THEME.BORDER
    s.Thickness   = thick or 1
    s.Transparency = trans or 0
    s.Parent = p; return s
end

local function label(p, props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.TextColor3  = THEME.TEXT
    l.Font        = Enum.Font.GothamMedium
    l.TextSize    = 13
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    l.RichText    = true
    for k,v in props do l[k]=v end
    l.Parent = p; return l
end

local function btn(p, props, accent)
    local b = Instance.new("TextButton")
    b.BackgroundColor3  = accent or THEME.ACCENT
    b.AutoButtonColor   = false
    b.BorderSizePixel   = 0
    b.Font              = Enum.Font.GothamBold
    b.TextColor3        = Color3.new(1,1,1)
    b.TextSize          = 12
    for k,v in props do b[k]=v end
    b.Parent = p
    corner(b, 6)

    -- Hiệu ứng nhấn touch/click
    local function pressIn()
        TweenService:Create(b, TW_FAST,
            {BackgroundTransparency=0.35, Size=b.Size - UDim2.fromOffset(2,2)}
        ):Play()
    end
    local function pressOut()
        TweenService:Create(b, TW_FAST,
            {BackgroundTransparency=0, Size=b.Size + UDim2.fromOffset(2,2)}
        ):Play()
    end
    b.MouseButton1Down:Connect(pressIn)
    b.MouseButton1Up:Connect(pressOut)
    b.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch then pressIn() end
    end)
    b.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch then pressOut() end
    end)
    return b
end

