-- MODULE 10: GAME EVENT HOOKS
-- ════════════════════════════════════════════════════════════
local charConns = {}  -- Connections riêng cho character (reset mỗi respawn)

local function hookCharacter(char)
    -- Xóa connections cũ trước
    for _, c in charConns do
        if c.Connected then c:Disconnect() end
    end
    table.clear(charConns)

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        LOG:write("WARN", "CHAR", "Không tìm thấy Humanoid trong Character!")
        return
    end

    LOG:write("EVENT", "CHAR", "Character hooked: "..char.Name)

    -- Health
    charConns[#charConns+1] = humanoid.HealthChanged:Connect(function(hp)
        LOG:write("INFO", "HEALTH",
            string.format("HP thay đổi → %.1f / %.1f", hp, humanoid.MaxHealth),
            {pct=math.floor(hp/humanoid.MaxHealth*100)})
    end)

    -- State
    charConns[#charConns+1] = humanoid.StateChanged:Connect(function(_, new)
        LOG:write("DEBUG", "STATE", tostring(new))
    end)

    -- Died
    charConns[#charConns+1] = humanoid.Died:Connect(function()
        LOG:write("WARN", "CHAR", "Nhân vật đã chết.")
    end)

    -- Tool equipped/unequipped
    charConns[#charConns+1] = char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            LOG:write("EVENT", "TOOL", "Trang bị: "..child.Name)
        end
    end)
    charConns[#charConns+1] = char.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") then
            LOG:write("EVENT", "TOOL", "Bỏ trang bị: "..child.Name)
        end
    end)

    -- Cleanup khi char bị destroy
    charConns[#charConns+1] = char.AncestryChanged:Connect(function(_, p)
        if not p then
            LOG:write("DEBUG", "CHAR", "Character removed from Workspace.")
        end
    end)

    -- Position logger mỗi 3 giây (nhẹ)
    local posConn
    posConn = RunService.Heartbeat:Connect(function()
        -- Chỉ log mỗi 3s dùng os.clock
        if not posConn then return end
    end)

    -- Thay bằng loop tách biệt để tránh Heartbeat overhead
    task.spawn(function()
        while humanoid and humanoid.Parent do
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local p = root.Position
                LOG:write("DEBUG", "POS",
                    string.format("(%.1f, %.1f, %.1f)", p.X, p.Y, p.Z))
            end
            task.wait(3)
        end
    end)
end

-- Hook character hiện tại
