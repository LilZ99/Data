-- MODULE 3: CLIPBOARD EXPORTER (Async Chunked)
-- ════════════════════════════════════════════════════════════

-- Serialize 1 entry → 1 dòng, chỉ 1 string.format allocation
local function serializeEntry(e)
    local dtStr = ""
    if e.dt then
        local parts = {}
        if type(e.dt) == "table" then
            for k, v in e.dt do
                parts[#parts+1] = tostring(k).."="..tostring(v)
            end
            dtStr = " {"..table.concat(parts, ", ").."}"
        else
            dtStr = " ["..tostring(e.dt).."]"
        end
    end
    return string.format("[%08.3f] %-5s | %-10s | %s%s",
        e.t, e.lv, e.ct, e.ms, dtStr)
end

local function exportAsync(logBuf, levelFilter, catFilter, onProgress, onDone)
    task.spawn(function()
        local entries = logBuf:getFiltered(levelFilter, catFilter)
        local total   = #entries
        if total == 0 then
            onDone(false, "Không có log nào để copy.")
            return
        end

        local lines     = table.create(total)
        local processed = 0
        local HEADER    = string.format(
            "=== ROBLOX DEBUG LOG | %s | %d entries | %s ===\n",
            CFG.TOOL_NAME, total, os.date and os.date("%Y-%m-%d") or "N/A"
        )

        -- Serialize theo chunk, yield giữa các chunk
        while processed < total do
            local chunkEnd  = math.min(processed + CFG.CHUNK_SIZE, total)
            local t0        = os.clock()

            for i = processed + 1, chunkEnd do
                lines[i] = serializeEntry(entries[i])
            end
            processed = chunkEnd

            if onProgress then
                task.defer(onProgress, math.floor(processed/total*100))
            end

            -- Yield nếu đã dùng quá 10ms trong chunk này
            if os.clock() - t0 > 0.010 then
                task.wait()
            end
        end

        -- O(n) join — không nối chuỗi trong vòng lặp
        local fullText = HEADER .. table.concat(lines, "\n")

        local ok, err = pcall(setclipboard, fullText)

        -- Giải phóng RAM ngay
        lines    = nil
        fullText = nil
        entries  = nil

        if ok then
            onDone(true, string.format("✅ Đã copy %d dòng log!", total))
        else
            onDone(false, "❌ Lỗi clipboard: " .. tostring(err))
        end
    end)
end

